{
  "name": "@sincronia/platform",
  "version": "2.0.0-next.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "description": "Next-generation ServiceNow developer platform centered on SDK + Fluent",
  "engines": {
    "node": ">=18.18.0"
  },
  "workspaces": [
    "apps/*",
    "packages/cli",
    "packages/core",
    "packages/plugin-servicenow",
    "packages/plugin-fluent",
    "packages/plugin-lint",
    "packages/plugin-ci",
    "packages/testing",
    "packages/types"
  ],
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rimraf node_modules",
    "dev": "npm run dev -w @sincronia/cli -- dev --watch",
    "deploy": "npm run dev -w @sincronia/cli -- deploy",
    "lint": "turbo run lint",
    "sincronia": "npm run dev -w @sincronia/cli --",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "@vitest/coverage-v8": "^3.2.4",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
